{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "angular",
  "installCommand": "npm ci --legacy-peer-deps",
  "buildCommand": "npm run build:production",
  "outputDirectory": "dist/grid-king/browser",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
